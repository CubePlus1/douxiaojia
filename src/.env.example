# FavToSkill 环境变量配置模板
# 复制本文件为 .env.local 并填入真实值（.env.local 已被 .gitignore 排除）

# ─── AI 接口（生成/分类 Skill 必填）─────────────────────────
# 走 OpenAI 兼容协议
# 选项：DashScope（通义千问）/ OpenAI / OpenRouter / 本地 Ollama（http://localhost:11434/v1）
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# ─── Phase B（视频抓取）── 按需填写 ─────────────────────────

# Bilibili 登录凭证（会员 / 付费内容需要；公开视频不用填）
# 从浏览器 devtools → Application → Cookies 里拷 SESSDATA 的值
# BILIBILI_COOKIES=

# YouTube 代理（国内访问 YouTube CDN 必填，否则字幕拉不到）
# 例：HTTP/SOCKS 都行 → http://127.0.0.1:7897 或 socks5://127.0.0.1:7897
# YOUTUBE_PROXY=

# YouTube 登录 cookies（年龄限制 / 会员视频需要）
# YOUTUBE_COOKIES=

# 抓取超时（毫秒），默认 90000
# VIDEO_EXTRACT_TIMEOUT=
