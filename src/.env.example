# FavToSkill 环境变量配置模板
# -------------------------------------------------------------------
# 复制本文件为 .env.local 并填入真实值。
# .env.local 已被 .gitignore 排除，不会进 git。
# -------------------------------------------------------------------


# ════════════════════════════════════════════════════════════════════
# AI 接口（必填）
# ════════════════════════════════════════════════════════════════════
#
# 走 OpenAI 兼容协议（chat/completions）。任何兼容的 endpoint 都能用。
# 下面给了 3 套常用预设，取消注释一套，删掉其它两套。
#
# generateObject 要求模型支持 JSON mode。小模型（<7B）可能不稳定，
# 可以重试，但建议用至少 "mini" 级模型。

# ─── 预设 1：阿里云 DashScope（通义千问）推荐 ─────────────────
# 中文友好、价格便宜、国内直连无需代理。
# 申请：https://dashscope.console.aliyun.com/apiKey
# AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AI_MODEL=qwen-plus

# ─── 预设 2：OpenAI ──────────────────────────────────────────
# 最稳定，英文最佳，贵。
# 申请：https://platform.openai.com/api-keys
# AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# ─── 预设 3：本地 Ollama（免费 / 离线）────────────────────────
# 要求本机 ollama serve 正在运行，且已 pull 对应模型。
# 小模型 JSON mode 较差，建议 qwen2.5:14b+ 或 llama3.1:8b+。
# AI_API_KEY=ollama
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=qwen2.5:14b

# 主要实际配置（必填；不要跟上面预设重复）：
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=


# ════════════════════════════════════════════════════════════════════
# 视频抓取（Phase B，按需填写）
# ════════════════════════════════════════════════════════════════════

# ─── YouTube 代理（国内必填）──────────────────────────────
# YouTube 字幕走 Google CDN，国内网络直连几乎必定 TLS 握手失败。
# 本机跑 Clash / v2rayN / Shadowrocket 后，取其 HTTP 或 SOCKS 端口。
# 支持格式：http://host:port  或  socks5://host:port
# 常见默认端口：Clash 7890 / Clash for Windows 7897 / v2rayN 10808
# YOUTUBE_PROXY=http://127.0.0.1:7897

# ─── Bilibili 登录凭证 ────────────────────────────────────
# 公开视频不用填。付费内容 / 会员视频 / 部分 UP 主限登录视频需要。
# 取值步骤：
#   1. Chrome 登录 bilibili.com
#   2. F12 → Application → Cookies → https://www.bilibili.com
#   3. 复制 SESSDATA 的值，粘到下面
# 格式支持：
#   - 单 cookie 字符串：SESSDATA=xxx
#   - 多 cookie 分号分隔：SESSDATA=xxx; bili_jct=yyy
#   - 或给 Netscape 格式 cookies.txt 的绝对路径
# BILIBILI_COOKIES=SESSDATA=xxx

# ─── YouTube 登录 cookies（很少需要）─────────────────────
# 仅年龄限制 / 会员制 / 部分私有视频需要。公开视频留空。
# 格式同 BILIBILI_COOKIES。
# YOUTUBE_COOKIES=

# ─── 抓取超时（毫秒）─────────────────────────────────────
# 默认 90000。长视频或慢网络可调大。
# VIDEO_EXTRACT_TIMEOUT=90000


# ════════════════════════════════════════════════════════════════════
# Phase C：意图驱动的切片 RAG（规划中，暂未生效）
# ════════════════════════════════════════════════════════════════════
# 设计文档：docs/design/03-intent-driven-rag.md
#
# 以下变量是 Phase C 落地后才会读取，现在填了也没效果，
# 放这里是为了让你知道未来的调参点：

# 切片触发阈值（transcript 字数超过此值才启用切片；默认 3000）
# SKILL_CHUNK_THRESHOLD=3000

# 每次检索返回的 top-K 切片数（默认 5）
# SKILL_CHUNK_TOP_K=5

# 是否启用 LLM 意图关键词扩展（C-2）；默认 true
# SKILL_INTENT_EXPANSION=true
